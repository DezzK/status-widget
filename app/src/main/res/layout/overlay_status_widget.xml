<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlay_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <!-- Status-bar mode containers + spacers. Hidden in floating mode; bricks live as direct
         children of the root then. WidgetService rearranges things at runtime. -->
    <LinearLayout
        android:id="@+id/startGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <View
        android:id="@+id/startCenterSpacer"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/centerGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <View
        android:id="@+id/centerEndSpacer"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/endGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <dezz.status.widget.OutlineTextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:textColor="@color/text_primary"
        android:textSize="100sp"
        tools:text="10:00" />

    <dezz.status.widget.OutlineTextView
        android:id="@+id/dateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:fontFamily="@font/roboto_condensed_medium"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        tools:text=" Tue, 10 Nov " />

    <LinearLayout
        android:id="@+id/mediaContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:visibility="gone">

        <dezz.status.widget.OutlineTextView
            android:id="@+id/mediaAppText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_condensed_medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            tools:text="Spotify"
            tools:visibility="visible" />

        <dezz.status.widget.OutlineTextView
            android:id="@+id/mediaTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_condensed_medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            tools:text="Track — Artist"
            tools:visibility="visible" />
    </LinearLayout>

    <dezz.status.widget.OutlineImageView
        android:id="@+id/wifiStatusIcon"
        android:layout_width="100sp"
        android:layout_height="100sp"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="4sp"
        android:src="@drawable/ic_status_wifi_off"
        tools:ignore="ContentDescription" />

    <dezz.status.widget.OutlineImageView
        android:id="@+id/gnssStatusIcon"
        android:layout_width="100sp"
        android:layout_height="100sp"
        android:layout_gravity="center_vertical"
        android:paddingHorizontal="4sp"
        android:src="@drawable/ic_status_gps_off"
        tools:ignore="ContentDescription" />
</LinearLayout>
