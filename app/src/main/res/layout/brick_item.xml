<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/brickCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/optionsMarginSmall"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/optionsMarginSmall">

        <LinearLayout
            android:id="@+id/brickHeader"
            android:layout_width="match_parent"
            android:layout_height="?attr/listPreferredItemHeightSmall"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/brickDragHandle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/brick_drag_handle"
                android:src="@drawable/ic_drag_handle" />

            <TextView
                android:id="@+id/brickTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/optionsMarginSmall"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                tools:text="Time" />

            <ImageView
                android:id="@+id/brickExpand"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/brick_expand"
                android:src="@drawable/ic_expand_more" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/brickPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/optionsMarginSmall"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/brickSizeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_font_size"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickSizeSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="20"
                        android:valueFrom="10"
                        android:valueTo="500" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/optionsMarginSmall"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_adjust_y"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickAdjustYSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="0"
                        android:valueFrom="-100"
                        android:valueTo="100" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/optionsMarginSmall"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_outline_alpha"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickOutlineAlphaSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="170"
                        android:valueFrom="0"
                        android:valueTo="255" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/optionsMarginSmall"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_outline_width"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickOutlineWidthSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="2"
                        android:valueFrom="0"
                        android:valueTo="20" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/optionsMarginSmall"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_margin_start"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickMarginStartSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="0"
                        android:valueFrom="0"
                        android:valueTo="300" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/optionsMarginSmall"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/brick_margin_end"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/brickMarginEndSlider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="0"
                        android:valueFrom="0"
                        android:valueTo="300" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/brickFontBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/optionsMargin"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/brick_font_family">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/brickFontFamilyDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/brickFontStyleGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/optionsMarginSmall"
                    app:singleSelection="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/brickFontBold"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/brick_font_bold"
                        android:minWidth="0dp"
                        android:paddingHorizontal="@dimen/optionsMargin"
                        android:text="@string/brick_font_bold_short"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/brickFontItalic"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/brick_font_italic"
                        android:minWidth="0dp"
                        android:paddingHorizontal="@dimen/optionsMargin"
                        android:text="@string/brick_font_italic_short"
                        android:textStyle="italic" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/brickStatusAlignmentLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/optionsMargin"
                android:hint="@string/brick_status_alignment"
                android:visibility="gone">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/brickStatusAlignmentDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/brickDateBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickDateShowDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/show_date"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickDateShowDayOfWeek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/show_day_of_the_week"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickDateShowFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/show_full_day_and_month"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickDateBeforeDayOfWeek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/date_before_day_of_week"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickDateOneLineLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/one_line_layout"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMargin"
                    android:hint="@string/calendar_alignment">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/brickDateAlignmentDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/brickGpsBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/brickGpsShowSatelliteBadge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:minHeight="@dimen/optionsLineHeight"
                    android:text="@string/show_gnss_satellite_badge"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/show_gnss_satellite_badge_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/brickMediaBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:text="@string/brick_media_max_width"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/brickMediaMaxWidthSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:value="500"
                    android:valueFrom="100"
                    android:valueTo="1000" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:text="@string/show_media_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/brickMediaPermissionButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:text="@string/grant_notification_access" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/brickHideOwnBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/brickHideInAppsButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMargin"
                    android:text="@string/brick_hide_in_apps" />

                <TextView
                    android:id="@+id/brickHideApplyToLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:text="@string/brick_hide_apply_to"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/brickHideApplyToChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/brickHideInheritedBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/brickHideInheritedHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMargin"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/brickHideUseOwnButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/optionsMarginSmall"
                    android:text="@string/brick_hide_use_own_list" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/optionsMargin"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/brickResetButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/brick_reset_button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/brickRemoveButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/optionsMarginSmall"
                    android:layout_weight="1"
                    android:text="@string/remove_element" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
