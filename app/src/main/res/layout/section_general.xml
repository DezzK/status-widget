<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/sectionPadding">

        <!-- Section header doubles as a toolbar: title on the left, action buttons on the right. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/optionsMarginSmall"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/sectionHeaderIconSize"
                android:layout_height="@dimen/sectionHeaderIconSize"
                android:layout_marginEnd="@dimen/optionsMarginSmall"
                android:src="@drawable/ic_section_widget"
                app:tint="?attr/colorPrimary"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/section_general"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/aboutButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_about"
                app:icon="@drawable/ic_info" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/optionsMarginSmall"
                android:text="@string/menu_export_settings"
                app:icon="@drawable/ic_export" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/importButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/optionsMarginSmall"
                android:text="@string/menu_import_settings"
                app:icon="@drawable/ic_import" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/enableWidgetSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/optionsMarginSmall"
            android:minHeight="@dimen/optionsLineHeight"
            android:text="@string/enable_widget"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/optionsMarginSmall"
            android:hint="@string/widget_mode">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/widgetModeDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/widgetAlignRightSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/optionsLineHeight"
            android:text="@string/widget_align_right"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/optionsMarginSmall"
            android:text="@string/widget_align_right_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/optionsMargin"
            android:text="@string/widget_position_x"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.slider.Slider
            android:id="@+id/widgetPositionXSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="0"
            android:valueFrom="0"
            android:valueTo="1080" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/optionsMarginSmall"
            android:text="@string/widget_position_y"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.slider.Slider
            android:id="@+id/widgetPositionYSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="0"
            android:valueFrom="0"
            android:valueTo="1920" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/hideInAppsButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/optionsMarginSmall"
            android:text="@string/hide_in_apps_button" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
